    <!-- 自訂 Toast 提示 -->
    <div id="toast" class="toast-msg">🔊 播放圍頭話發音 (模擬)</div>

    <script>
        (function(){
            // 簡單的toast提示，代替真實音檔
            const toast = document.getElementById('toast');

            function showToast(word) {
                toast.textContent = `🔊 圍頭話發音： ${word} (模擬)`;
                toast.classList.add('show');
                setTimeout(() => {
                    toast.classList.remove('show');
                }, 1500);
            }

            // 綁定所有發音按鈕 (包含 .sound-btn, .small-sound, .mini-sound, .dict-sound)
            const soundButtons = document.querySelectorAll('.sound-btn, .small-sound, .mini-sound, .dict-sound');
            soundButtons.forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    // 嘗試從 data-word 取得食物名，若無則找父層的文字
                    let word = btn.getAttribute('data-word');
                    if (!word) {
                        // 找父層內的 .snack-name 或相鄰文字
                        const parent = btn.closest('.snack-card, .dish-card, .scroll-item, .dict-item, .pun-choi-desc');
                        if (parent) {
                            const nameEl = parent.querySelector('.snack-name, h4, .dict-item');
                            word = nameEl ? nameEl.innerText.trim() : '食物';
                        } else {
                            word = '食物';
                        }
                    }
                    showToast(word);
                });
            });

            // 食譜下載按鈕模擬
            const downloadBtns = document.querySelectorAll('.download-btn');
            downloadBtns.forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    const recipe = btn.getAttribute('data-recipe') || '食譜';
                    alert(`📥 下載模擬：${recipe}食譜.pdf (實際上下載功能可串接下載連結)`);
                });
            });

            // 影片卡片點擊模擬
            const videoCards = document.querySelectorAll('.video-card');
            videoCards.forEach(card => {
                card.addEventListener('click', () => {
                    alert('🎬 模擬播放影片 (此為示意，實際可嵌入YouTube/Vimeo)');
                });
            });

            // 盆菜層懸停效果（原本已有，額外可加入點擊顯示對應說明）
            const layerItems = document.querySelectorAll('.layer-item');
            layerItems.forEach((item, index) => {
                item.addEventListener('click', () => {
                    const layerName = item.querySelector('.layer-name')?.innerText || `第${index+1}層`;
                    showToast(`盆菜：${layerName}`);
                });
            });

            // 向下箭頭滾動
            document.querySelector('.scroll-down').addEventListener('click', ()=>{
                window.scrollTo({ top: window.innerHeight, behavior: 'smooth' });
            });

        })();
    </script>
